# ============================================
# IdeaPark 环境变量
# ============================================

# PostgreSQL 数据库连接（必填）
# 推荐免费服务：Neon (https://neon.tech)、Supabase (https://supabase.com)、Vercel Postgres
#
# Neon 示例：
#   DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/ideapark?sslmode=require"
#   DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/ideapark?sslmode=require"
#
# Supabase 示例（Pooler 模式 + 直连）：
#   DATABASE_URL="postgresql://postgres.xxx:pass@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
#   DIRECT_URL="postgresql://postgres.xxx:pass@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

DATABASE_URL="postgresql://user:password@host:5432/ideapark?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/ideapark?sslmode=require"

# NextAuth 配置（必填）
# NEXTAUTH_SECRET: 用 `openssl rand -base64 32` 生成随机密钥
NEXTAUTH_SECRET="your-secret-key-here"

# NEXTAUTH_URL: 本地开发用 http://localhost:3000，Vercel 部署时会自动设置，无需配置
NEXTAUTH_URL="http://localhost:3000"
