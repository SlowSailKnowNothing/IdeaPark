{
  "name": "ideapark",
  "version": "1.0.0",
  "private": true,
  "description": "IdeaPark - An idea management API built with Cloudflare Workers + D1",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute ideapark-db --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute ideapark-db --remote --file=./schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "typescript": "^5.7.3",
    "wrangler": "^3.114.1"
  }
}
