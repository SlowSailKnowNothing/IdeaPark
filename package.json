{
  "name": "ideapark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create ideapark-db",
    "db:migrate": "wrangler d1 migrations apply ideapark-db",
    "db:migrate:local": "wrangler d1 migrations apply ideapark-db --local",
    "db:seed": "wrangler dev --local -- npm run seed:run",
    "seed:run": "tsx scripts/seed.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@noble/hashes": "^1.4.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240321.0",
    "@types/node": "^25.5.0",
    "eslint": "^8.57.0",
    "tsx": "^4.10.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.78.0"
  }
}
